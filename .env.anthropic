# MURM Local Configuration - Anthropic
# Replace YOUR_ANTHROPIC_KEY_HERE with the key from console.anthropic.com

LLM_MODEL=claude-3-5-haiku-20241022
LLM_API_KEY=YOUR_ANTHROPIC_KEY_HERE

# Haiku is extremely cheap for agent turns
AGENT_MODEL=claude-3-5-haiku-20241022
AGENT_API_KEY=YOUR_ANTHROPIC_KEY_HERE

TOKEN_BUDGET=300000

# NEWS / REAL-TIME GROUNDING
NEWS_PROVIDER=wikipedia
# NEWS_API_KEY=your_news_api_key

DATA_DIR=data
CHROMA_PATH=data/chroma
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

DEFAULT_AGENTS=20
DEFAULT_ROUNDS=15
DEFAULT_SEED=42
LOG_LEVEL=INFO
