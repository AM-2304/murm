# MURM Local Configuration — OpenAI
# Replace YOUR_OPENAI_KEY_HERE with the key from platform.openai.com

LLM_MODEL=gpt-4o-mini
LLM_API_KEY=YOUR_OPENAI_KEY_HERE

# Use gpt-4o-mini for agents too - it's cheap enough
AGENT_MODEL=gpt-4o-mini
AGENT_API_KEY=YOUR_OPENAI_KEY_HERE

# $0.30 safety cap - about 4 test runs
TOKEN_BUDGET=500000

DATA_DIR=data
CHROMA_PATH=data/chroma
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

DEFAULT_AGENTS=20
DEFAULT_ROUNDS=15
DEFAULT_SEED=42
LOG_LEVEL=INFO
