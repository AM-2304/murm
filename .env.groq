
# MURM Local Configuration
# Replace the values below with your actual keys.
# !!! This file must NEVER be committed to git.


# PRIMARY LLM (graph building, ontology, report writing)
# Using Groq for fast, cheap testing.
# Replace YOUR_GROQ_KEY_HERE with the key from console.groq.com
LLM_MODEL=groq/llama-3.3-70b-versatile
LLM_API_KEY=YOUR_GROQ_KEY_HERE

# AGENT MODEL (per-agent inference inside simulation) ---
# Use a smaller, faster model for the agents to save cost.
# The orchestration model above handles quality-critical tasks.
# Remove the # from these two lines:
AGENT_MODEL=groq/llama-3.1-8b-instant
AGENT_API_KEY=YOUR_GROQ_KEY_HERE

# COST SAFETY NET
# Maximum tokens before the simulation hard-stops.
# 200000 = roughly $0.20 on Groq, enough for a 50-agent 30-round test.
# Set to 0 to remove the cap entirely.
TOKEN_BUDGET=200000

# LOCAL STORAGE
# All data stays on your machine. No cloud storage needed.
DATA_DIR=data
CHROMA_PATH=data/chroma

# WEB SERVER
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# SIMULATION DEFAULTS
# These are the values pre-filled in the UI.
# You can always override them per run.
DEFAULT_AGENTS=20
DEFAULT_ROUNDS=15
DEFAULT_SEED=42

# LOGGING
# Use DEBUG to see every LLM call and its token count.
# Use INFO for normal operation.
LOG_LEVEL=INFO
